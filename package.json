{
  "name": "omp-project-time",
  "version": "7.0.0",
  "description": "Verifiable concurrent project-work logs for OMP.",
  "type": "module",
  "license": "MIT",
  "files": [
    "src",
    "dist",
    "spec",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "THIRD_PARTY_NOTICES.txt"
  ],
  "scripts": {
    "build": "npm run build:types && npm run build:source && npm run build:vendor && npm run format:dist",
    "build:types": "rm -rf dist && tsc --noEmit -p tsconfig.json",
    "build:source": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "build:vendor": "node scripts/bundle-runtime-dependencies.mjs",
    "format:dist": "prettier --write dist && node scripts/separate-generated-declarations.mjs",
    "test": "node --import tsx --test test/*.test.ts"
  },
  "keywords": [
    "omp",
    "oh-my-pi",
    "plugin",
    "statusline",
    "project-time"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/klondikemarlen/omp-project-time.git"
  },
  "homepage": "https://github.com/klondikemarlen/omp-project-time#readme",
  "bugs": {
    "url": "https://github.com/klondikemarlen/omp-project-time/issues"
  },
  "omp": {
    "extensions": [
      "./dist/omp-extension.js"
    ],
    "settings": {
      "Active Window Minutes": {
        "type": "number",
        "default": 5,
        "min": 1,
        "description": "Keeps Project Time active for this many minutes after a user prompt."
      },
      "Refresh Interval Seconds": {
        "type": "number",
        "default": 15,
        "min": 1,
        "description": "Refreshes the active status every this many seconds."
      },
      "Status Label": {
        "type": "string",
        "default": "dev",
        "description": "Shows this lowercase suffix in the status line, for example dev."
      }
    }
  },
  "dependencies": {
    "@oh-my-pi/pi-coding-agent": "^17.0.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/proper-lockfile": "^4.1.4",
    "esbuild": "^0.28.1",
    "prettier": "^3.9.5",
    "proper-lockfile": "^4.1.2",
    "tsc-alias": "^1.9.1",
    "tsx": "^4.20.6",
    "typescript": "^5.8.2"
  },
  "engines": {
    "node": ">=20.6.0"
  }
}
