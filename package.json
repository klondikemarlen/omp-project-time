{
  "name": "omp-project-time",
  "version": "2.1.1",
  "description": "Project time and billable work plugin for OMP.",
  "type": "module",
  "license": "MIT",
  "files": [
    "src",
    "dist",
    "spec",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "THIRD_PARTY_NOTICES.txt"
  ],
  "scripts": {
    "build": "npm run build:types && npm run build:source && npm run build:vendor && npm run format:dist",
    "build:types": "rm -rf dist && tsc --noEmit -p tsconfig.json",
    "build:source": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "build:vendor": "node scripts/bundle-runtime-dependencies.mjs",
    "format:dist": "prettier --write dist && node scripts/separate-generated-declarations.mjs",
    "test": "node --import tsx --test test/*.test.ts"
  },
  "keywords": [
    "omp",
    "oh-my-pi",
    "plugin",
    "statusline",
    "project-time",
    "billable-time"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/klondikemarlen/omp-project-time.git"
  },
  "homepage": "https://github.com/klondikemarlen/omp-project-time#readme",
  "bugs": {
    "url": "https://github.com/klondikemarlen/omp-project-time/issues"
  },
  "omp": {
    "extensions": [
      "./dist/index.js"
    ],
    "settings": {
      "monthlySalary": {
        "type": "number",
        "default": 6500,
        "min": 1,
        "description": "Monthly salary used for the Project Time meter."
      },
      "hoursPerWeek": {
        "type": "number",
        "default": 40,
        "min": 1,
        "description": "Working hours per week used for the Project Time meter."
      },
      "weeksPerYear": {
        "type": "number",
        "default": 52,
        "min": 1,
        "description": "Working weeks per year used for the Project Time meter."
      },
      "activeWindowMinutes": {
        "type": "number",
        "default": 5,
        "min": 1,
        "description": "How long one prompt keeps Project Time active."
      },
      "refreshIntervalSeconds": {
        "type": "number",
        "default": 15,
        "min": 1,
        "description": "How often the status text refreshes while the meter is active."
      },
      "label": {
        "type": "string",
        "default": "dev",
        "description": "Lowercase suffix shown in the status line, such as dev."
      },
      "billableTime": {
        "type": "string",
        "default": "{}",
        "description": "JSON client policies for billable time; defaultClient targets the active Git repository and projects can override its displayed name."
      }
    }
  },
  "dependencies": {
    "@oh-my-pi/pi-coding-agent": "^16.1.16",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/big.js": "^7.0.0",
    "@types/node": "^24.0.0",
    "@types/proper-lockfile": "^4.1.4",
    "big.js": "^7.0.1",
    "esbuild": "^0.28.1",
    "prettier": "^3.9.5",
    "proper-lockfile": "^4.1.2",
    "tsc-alias": "^1.9.1",
    "tsx": "^4.20.6",
    "typescript": "^5.8.2"
  },
  "engines": {
    "node": ">=20.6.0"
  }
}
